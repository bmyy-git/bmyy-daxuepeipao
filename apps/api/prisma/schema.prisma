generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MENTOR
  PROJECT_TEACHER
  COUNSELOR
  SCHOOL_TEACHER
  CUSTOMER_SERVICE
  STUDENT
  PARENT
}

enum StudentStage {
  ACTIVATING
  PENDING_MATCH
  MENTOR_MATCHED
  SOP_REVIEWING
  ACTIVE
  PAUSED
  GRADUATED
}

enum CardStatus {
  UNBOUND
  ACTIVE
  LOST
  REPLACED
  REVOKED
}

enum CardType {
  STUDENT_PRIMARY
  STUDENT_SECONDARY
  PARENT_FAMILY
  STAFF
}

enum TaskStatus {
  TODO
  DOING
  SUBMITTED
  CHANGES_REQUESTED
  ACCEPTED
  OVERDUE
  CANCELLED
}

enum SubmissionStatus {
  SUBMITTED
  WITHDRAWN
  ACCEPTED
  CHANGES_REQUESTED
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
  MENTOR_FEEDBACK
  CLOSED
}

enum RevisionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SopStatus {
  DRAFT
  REVIEWING
  CONFIRMED
  ARCHIVED
}

enum ParentRelationStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum DocumentStatus {
  UPLOADED
  VALIDATING
  REJECTED
  SCANNING
  PARSING
  AVAILABLE
  FAILED
}

enum BonusStatus {
  PENDING_EVIDENCE
  PENDING_REVIEW
  APPROVED
  PENDING_PAYMENT
  SETTLED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  role         Role
  phone        String?  @unique
  email        String?  @unique
  passwordHash String
  active       Boolean  @default(true)
  student      Student?
  mentor       Mentor?
  parentRelations ParentRelation[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Student {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id])
  name            String
  phone           String
  email           String?
  school          String
  college         String
  major           String
  grade           String
  goals           Json
  customGoal      String?
  stage           StudentStage @default(ACTIVATING)
  serviceMode     String?
  streak          Int          @default(0)
  parentConsent   Boolean      @default(false)
  parentScope     Json
  mentorId        String?
  mentor          Mentor?      @relation(fields: [mentorId], references: [id])
  tasks           Task[]
  sops            Sop[]
  reviews         PeriodReview[]
  goalRevisions   GoalRevision[]
  growthEvents    GrowthEvent[]
  messages        Message[]
  cards           CardBinding[]
  documents       Document[]
  honors          HonorRecord[]
  bonusLedger     BonusLedger[]
  parentRelations ParentRelation[]
  aiLogs          AiLog[]
  checkins        Checkin[]
  privacyConsents PrivacyConsent[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model PrivacyConsent {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  consentVersion String
  agreed         Boolean
  ip             String?
  userAgent      String?
  agreedAt       DateTime @default(now())
}

model ActivationSession {
  id        String     @id @default(cuid())
  cardId    String
  idh       String
  status    String     @default("active")
  draft     Json
  expiresAt DateTime
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Mentor {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  name         String
  title        String
  avatar       String
  tags         Json
  expertise    Json
  email        String
  wechat       String
  meeting      String
  rating       Int
  serviceCount Int
  students     Student[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NfcCard {
  idd         String       @id
  idh         String       @unique
  type        CardType
  label       String
  status      CardStatus   @default(UNBOUND)
  bindings    CardBinding[]
  accessLogs  NfcAccessLog[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CardBinding {
  id         String   @id @default(cuid())
  cardId     String
  card       NfcCard  @relation(fields: [cardId], references: [idd])
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  subjectType String
  subjectId  String
  cardType   CardType
  isPrimary  Boolean  @default(false)
  status     String   @default("active")
  boundAt    DateTime @default(now())
  endedAt    DateTime?
  @@index([studentId, status])
}

model NfcAccessLog {
  id             String   @id @default(cuid())
  cardId         String?
  card           NfcCard? @relation(fields: [cardId], references: [idd])
  idh            String?
  resolvedStatus String
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())
}

model Sop {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  version     String
  status      SopStatus
  summary     String
  content     Json
  createdBy   String
  confirmedBy String?
  confirmedAt DateTime?
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@unique([studentId, version])
}

model Task {
  id          String     @id @default(cuid())
  studentId   String
  student     Student    @relation(fields: [studentId], references: [id])
  sopId       String
  sop         Sop        @relation(fields: [sopId], references: [id])
  title       String
  description String
  category    String
  priority    String
  deadline    DateTime
  criteria    Json
  semester    String
  status      TaskStatus @default(TODO)
  mentorNote  String
  submissions TaskSubmission[]
  checkins    Checkin[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Checkin {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model TaskSubmission {
  id            String           @id @default(cuid())
  taskId        String
  task          Task             @relation(fields: [taskId], references: [id])
  studentId     String
  version       Int
  content       String
  evidenceLinks Json
  fileNames     Json
  selfRating    Int
  blockers      String
  status        SubmissionStatus @default(SUBMITTED)
  submittedAt   DateTime         @default(now())
  reviews       TaskReview[]
  @@unique([taskId, version])
}

model TaskReview {
  id           String   @id @default(cuid())
  submissionId String
  submission   TaskSubmission @relation(fields: [submissionId], references: [id])
  reviewerId   String
  decision     String
  comment      String
  requirements Json
  reviewedAt   DateTime @default(now())
}

model PeriodReview {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  period         String
  type           String
  wins           String
  unfinished     String
  blocker        String
  mood           Int
  support        String
  nextGoal       String
  status         ReviewStatus @default(SUBMITTED)
  mentorFeedback String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GoalRevision {
  id         String         @id @default(cuid())
  studentId  String
  student    Student        @relation(fields: [studentId], references: [id])
  oldGoals   Json
  newGoals   Json
  reason     String
  aiAnalysis Json
  status     RevisionStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime       @default(now())
}

model GrowthEvent {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  type        String
  title       String
  description String
  eventDate   DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  fromRole  String
  title     String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model HonorRecord {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  title       String
  description String
  status      String
  earnedAt    DateTime?
  createdAt   DateTime @default(now())
}

model BonusLedger {
  id          String      @id @default(cuid())
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id])
  amount      Decimal     @db.Decimal(12, 2)
  direction   String
  status      BonusStatus
  description String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ParentRelation {
  id           String               @id @default(cuid())
  parentUserId String
  parentUser   User                 @relation(fields: [parentUserId], references: [id])
  studentId    String
  student      Student              @relation(fields: [studentId], references: [id])
  relationship String
  consentScope Json
  status       ParentRelationStatus @default(PENDING)
  verifiedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  @@unique([parentUserId, studentId])
}

model Document {
  id               String         @id @default(cuid())
  studentId        String?
  student          Student?       @relation(fields: [studentId], references: [id])
  activationSessionId String?
  activationSession ActivationSession? @relation(fields: [activationSessionId], references: [id])
  ownerType        String
  ownerId          String
  originalFileName String
  storedFileName   String
  mimeType         String
  fileSize         Int
  sha256           String
  storagePath      String
  status           DocumentStatus @default(UPLOADED)
  difyDocumentId   String?
  summary          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model AiLog {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  userId         String
  conversationId String?
  scenario       String
  question       String
  answer         String
  sources        Json
  needMentor     Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String
  actorRole    String
  action       String
  resourceType String
  resourceId   String
  detail       Json
  ip           String?
  createdAt    DateTime @default(now())
}
